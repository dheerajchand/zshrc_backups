# =================================================================
# ZSH VARIABLES - MAC OVERRIDES
# =================================================================
# Loaded after vars.env when OSTYPE=darwin.

# Keep local workstation profile semantics on macOS.
export ZSH_ENV_PROFILE="${ZSH_ENV_PROFILE:-laptop}"

# IDE terminals are common on local Mac; keep adaptive startup.
export ZSH_STARTUP_MODE="${ZSH_STARTUP_MODE:-auto}"

# Keep local data services auto-recovery enabled by default.
export ZSH_AUTO_RECOVER_DATA_SERVICES="${ZSH_AUTO_RECOVER_DATA_SERVICES:-1}"
export ZSH_AUTO_RECOVER_IN_IDE="${ZSH_AUTO_RECOVER_IN_IDE:-0}"

# Django GIS / GDAL defaults for macOS (Homebrew).
# Prefer explicit mac profile values; settings module can still auto-detect as fallback.
if [[ -z "${GDAL_LIBRARY_PATH:-}" ]]; then
    if [[ -f "/opt/homebrew/opt/gdal/lib/libgdal.dylib" ]]; then
        export GDAL_LIBRARY_PATH="/opt/homebrew/opt/gdal/lib/libgdal.dylib"
    elif [[ -f "/usr/local/opt/gdal/lib/libgdal.dylib" ]]; then
        export GDAL_LIBRARY_PATH="/usr/local/opt/gdal/lib/libgdal.dylib"
    fi
fi

if [[ -z "${GEOS_LIBRARY_PATH:-}" ]]; then
    if [[ -f "/opt/homebrew/opt/geos/lib/libgeos_c.dylib" ]]; then
        export GEOS_LIBRARY_PATH="/opt/homebrew/opt/geos/lib/libgeos_c.dylib"
    elif [[ -f "/usr/local/opt/geos/lib/libgeos_c.dylib" ]]; then
        export GEOS_LIBRARY_PATH="/usr/local/opt/geos/lib/libgeos_c.dylib"
    fi
fi
