# =================================================================
# ZSH VARIABLES - CYBERPOWER HOST OVERRIDES
# =================================================================
# Loaded last on hostnames matching "cyberpower".

export ZSH_ENV_PROFILE="cyberpower"

# Cyberpower is used as a server-style environment.
export WORK_REPOS_ROOT="$HOME/git"
export PROFESSIONAL="$HOME/git"

# Avoid repeated interactive 1Password prompts in remote shells.
export ZSH_OP_AUTO_SIGNIN_ALL="0"
