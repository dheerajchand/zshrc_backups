# =================================================================
# ZSH VARIABLES - LINUX OVERRIDES
# =================================================================
# Loaded after vars.env when OSTYPE is Linux.

# Keep Linux shells predictable and avoid IDE-specific stagger unless requested.
export ZSH_STARTUP_MODE="full"

# Linux hosts often use server-style repo roots.
export WORK_REPOS_ROOT="${WORK_REPOS_ROOT:-$HOME/git}"
